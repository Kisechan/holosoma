<!-- Rubber duck scaled ~50x (MJCF, scale 0.5). Textured via explicit <texture>+<material>
     because MuJoCo's URDF importer ignores the OBJ .mtl. euler 90deg about x: Y-up -> Z-up.
     Footprint after scaling is ~2.0 x 3.6 m, ~2.9 m tall. -->
<mujoco model="huge_rubber_duck">
  <compiler angle="degree"/>
  <asset>
    <texture name="rubber_duck_tex" type="2d" file="RubberDuck_BaseColor.png"/>
    <material name="rubber_duck_mat" texture="rubber_duck_tex"/>
    <mesh name="rubber_duck_mesh" file="RubberDuck.obj" scale="0.5 0.5 0.5"/>
  </asset>
  <worldbody>
    <body name="baseLink">
      <geom type="mesh" mesh="rubber_duck_mesh" material="rubber_duck_mat" mass="2.5"
            euler="90 0 0" friction="0.9 0.5 0.05"/>
    </body>
  </worldbody>
</mujoco>
