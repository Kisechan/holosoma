<!-- Rubber duck (MJCF). MuJoCo's URDF importer ignores an OBJ's sidecar .mtl, so the
     textured look only survives through MJCF, where the PNG is bound explicitly as a
     <texture>+<material> on the mesh geom. Mesh is authored in centimeters and Y-up, so
     scale 0.01 converts cm->m and euler 90deg about x rotates Y-up -> Z-up. The scene
     manager adds a free joint for free bodies and leaves it jointless for static ones. -->
<mujoco model="rubber_duck">
  <compiler angle="degree"/>
  <asset>
    <texture name="rubber_duck_tex" type="2d" file="RubberDuck_BaseColor.png"/>
    <material name="rubber_duck_mat" texture="rubber_duck_tex"/>
    <mesh name="rubber_duck_mesh" file="RubberDuck.obj" scale="0.01 0.01 0.01"/>
  </asset>
  <worldbody>
    <body name="baseLink">
      <geom type="mesh" mesh="rubber_duck_mesh" material="rubber_duck_mat" mass="0.05"
            euler="90 0 0" friction="0.9 0.5 0.05"/>
    </body>
  </worldbody>
</mujoco>
