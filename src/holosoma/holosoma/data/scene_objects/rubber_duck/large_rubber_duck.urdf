<?xml version="1.0" ?>
<!-- Rubber duck scaled ~10x larger than rubber_duck.urdf (scale 0.1 instead of 0.01).
     Mesh (RubberDuck.obj) is authored in centimeters and Y-up, so rpy rotates Y-up -> Z-up.
     Footprint after scaling is ~0.40 x 0.72 m, ~0.58 m tall. Mass scaled 10x and inertia
     ~1000x (m*L^2) relative to the small duck. -->
<robot name="large_rubber_duck">
  <dynamics damping="0.5" friction="0.9"/>
  <link name="baseLink">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="3.6e-2" ixy="0" ixz="0" iyy="2.8e-2" iyz="0" izz="2.1e-2"/>
    </inertial>
    <contact>
      <lateral_friction value="0.9"/>
      <rolling_friction value="0.5"/>
      <stiffness value="30000"/>
      <damping value="1000"/>
    </contact>
    <visual>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="RubberDuck.obj" scale="0.1 0.1 0.1"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="RubberDuck.obj" scale="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
</robot>
