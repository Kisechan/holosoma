<!-- Rubber duck scaled ~10x (MJCF, scale 0.1). Textured via explicit <texture>+<material>
     because MuJoCo's URDF importer ignores the OBJ .mtl. euler 90deg about x: Y-up -> Z-up. -->
<mujoco model="large_rubber_duck">
  <compiler angle="degree"/>
  <asset>
    <texture name="rubber_duck_tex" type="2d" file="RubberDuck_BaseColor.png"/>
    <material name="rubber_duck_mat" texture="rubber_duck_tex"/>
    <mesh name="rubber_duck_mesh" file="RubberDuck.obj" scale="0.1 0.1 0.1"/>
  </asset>
  <worldbody>
    <body name="baseLink">
      <geom type="mesh" mesh="rubber_duck_mesh" material="rubber_duck_mat" mass="0.5"
            euler="90 0 0" friction="0.9 0.5 0.05"/>
    </body>
  </worldbody>
</mujoco>
